B3% := (B3% + 1)
ENDIF
I% := (I% + 1)
ENDWH
MCOUNT% := B0%
MBIOME% := 0
TCOUNT% := 1
IF (B1% > MCOUNT%)
MCOUNT% := B1%
MBIOME% := 1
TCOUNT% := 1
ELSEIF (B1% = MCOUNT%)
TCOUNT% := (TCOUNT% + 1)
ENDIF
IF (B2% > MCOUNT%)
MCOUNT% := B2%
MBIOME% := 2
TCOUNT% := 1
ELSEIF (B2% = MCOUNT%)
