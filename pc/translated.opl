ELSEIF (B3% = MCOUNT%)
TCOUNT% := (TCOUNT% + 1)
ENDIF
CCHAR$ := MID$(MAP$(PY%) PX% 1 )
CASCII% := ASC(CCHAR$ )
CBIOME% := (CASCII% AND 3)
IF (TCOUNT% > 1)
NBIOME% := CBIOME%
ELSE
NBIOME% := MBIOME%
ENDIF
NEWCODE% := ((CASCII% AND (UNOT 3)) OR NBIOME%)
NEWCHAR$ := CHR$(NEWCODE% )
CHNGMAP:(NEWCHAR$, )(PY%, )(PX%)
ELSE
ENDIF
PX% := (PX% + 1)
PROGR% := (PROGR% + 1)
CLS()
PRINT(PROGR%)
PRINT("/80")
<nl>

ENDWH
PY% := (PY% + 1)
ENDWH



