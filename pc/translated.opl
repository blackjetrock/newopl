PY% := 1
WHILE (PY% <= 4)
PX% := 1
WHILE (PX% <= 20)
IF ((PY% = 1) AND (PX% = 1))
NEIH$(1) := MID$(MAP$(PY%) PX% 1 )
NEIH$(2) := MID$(MAP$(PY%) PX% 1 )
NEIH$(3) := MID$(MAP$(PY%) (PX% + 1) 1 )
NEIH$(4) := MID$(MAP$(PY%) PX% 1 )
NEIH$(5) := MID$(MAP$(PY%) (PX% + 1) 1 )
