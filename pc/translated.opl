NEIH$(7) := MID$(MAP$((PY% + 1)) PX% 1 )
NEIH$(8) := MID$(MAP$((PY% + 1)) (PX% + 1) 1 )
ELSEIF ((PY% = 1) AND (PX% = 20))
NEIH$(1) := MID$(MAP$(PY%) (PX% - 1) 1 )
