IF (RANDVAL% < 7)
I% := 1
WHILE (I% <= 8)
LASCII%(I%) := ASC(NEIH$(I%) )
NEBIOME%(I%) := (LASCII%(I%) AND 3)
I% := (I% + 1)
ENDWH
B0% := 0
B1% := 0
B2% := 0
B3% := 0
